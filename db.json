var a = db.parents.aggregate([
    {
        $lookup: {
            from: "students",
            let: { parent_id: "$_id" },
            pipeline: [
                {
                    $match: {
                        $expr: {
                            $and: [
                                { $in: [ "$$parent_id", "$parents" ] }
                            ]
                        }
                    }
                }
            ],
            as: "students"
        }
    },
    {
        $project: {
            _id: 1,
            firstname: 1,
            lastname: 1,
            students: "$students"
        }
    },
    {
      $match: { "students": { $eq: [] } }
   }
]).forEach(function (p){
    db.parents.deleteOne({_id: p._id})
})

for (let i=0;i<a.length;i++){
    db.parents.deleteOne({_id: a[i]._id})
}